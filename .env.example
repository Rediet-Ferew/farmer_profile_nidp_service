COMMON_APP_HOST=0.0.0.0
COMMON_APP_PORT=8001

FARMER_DEDUP_DB_DRIVER=postgresql+asyncpg
FARMER_DEDUP_DB_USERNAME=
FARMER_DEDUP_DB_PASSWORD=
FARMER_DEDUP_DB_HOSTNAME=
FARMER_DEDUP_DB_PORT=5432
FARMER_DEDUP_DB_NAME=

FARMER_DEDUP_SERVICE_DB_DRIVER=postgresql+asyncpg
FARMER_DEDUP_SERVICE_DB_USERNAME=
FARMER_DEDUP_SERVICE_DB_PASSWORD=
FARMER_DEDUP_SERVICE_DB_HOSTNAME=
FARMER_DEDUP_SERVICE_DB_PORT=5432
FARMER_DEDUP_SERVICE_DB_NAME=
FARMER_DEDUP_SERVICE_DB_AUTO_MIGRATE=true

FARMER_DEDUP_NIDP_GET_DATA_BY_ID_URL=http://localhost:8000/getDataById
FARMER_DEDUP_NIDP_CALLER_ID=openg2p
FARMER_DEDUP_NIDP_API_VERSION=v1
FARMER_DEDUP_NIDP_TIMEOUT_SECONDS=1000
FARMER_DEDUP_MOCK_NIDP_ENABLED=false

FARMER_DEDUP_INCLUDE_ID_TYPES=UID,FAN,RID
FARMER_DEDUP_RESPONSE_ID_FIELD=fan
FARMER_DEDUP_RESPONSE_ID_TYPE=FAN
FARMER_DEDUP_PARTNER_UNIQUE_ID_PREFIX=
FARMER_DEDUP_REQUIRED_UPDATE_FIELDS=name,given_name,family_name,gender,birthdate,image_1920,first_name_amh,family_name_amh,gf_name_amh,gf_name_eng
# Path (inside this container) to Odoo's filestore for the target database, e.g.
# <odoo-data-dir>/filestore/<db_name>. Required for image_1920 to be persisted,
# since it is an attachment-backed field, not a physical res_partner column.
FARMER_DEDUP_ODOO_FILESTORE_DIR=
# When true, IDs whose last NIDP response was invalid (status='invalid' on the
# g2p_reg_id row - malformed FAN/FIN, FAILED/REJECTED from NIDP) are retried on
# every dedup run, same as IDs that are simply missing their image. When false,
# already-invalid IDs are left alone (won't keep hitting NIDP for permanently
# bad data); IDs that are valid/never-attempted but still missing an image are
# always retried regardless of this setting.
FARMER_DEDUP_RERUN_INVALID_RECORDS=true

FARMER_DEDUP_CHUNK_LIMIT=10
FARMER_DEDUP_FETCH_LIMIT=1000
FARMER_DEDUP_INTERVAL_SECONDS=300
FARMER_DEDUP_INITIAL_DELAY_SECONDS=5
FARMER_DEDUP_DRY_RUN=true
FARMER_DEDUP_BACKGROUND_ENABLED=false
FARMER_DEDUP_LOCK_ENABLED=true
FARMER_DEDUP_LOCK_ID=914202607

FARMER_DEDUP_APPROVAL_BACKGROUND_ENABLED=false
FARMER_DEDUP_APPROVAL_INTERVAL_SECONDS=300
FARMER_DEDUP_APPROVAL_INITIAL_DELAY_SECONDS=15
FARMER_DEDUP_APPROVAL_FETCH_LIMIT=1000
FARMER_DEDUP_APPROVAL_DRY_RUN=true
FARMER_DEDUP_APPROVAL_LOCK_ENABLED=true
FARMER_DEDUP_APPROVAL_LOCK_ID=914202608
FARMER_DEDUP_APPROVAL_VALID_ID_TYPES=UID,FIN,FAN,RID
FARMER_DEDUP_APPROVAL_RESPONSE_STATUS=PROCESSED
FARMER_DEDUP_APPROVAL_STATE=draft
FARMER_DEDUP_APPROVAL_WRITE_UID=
FARMER_DEDUP_APPROVAL_REQUIRE_FAN=false
FARMER_DEDUP_APPROVAL_REQUIRE_VALID_FAN=false
FARMER_DEDUP_APPROVAL_CHECK_GLOBAL_LAND_DUPLICATES=false

FARMER_DEDUP_LOG_LEVEL=INFO
